<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FoodApp.PaymentWindow"
        Title="Płatność" Width="350" Height="300">

    <StackPanel Margin="20">
        <TextBlock Text="Opcje płatności:" FontSize="18"/>

        <StackPanel>
            <RadioButton x:Name="PayCash" Content="Gotówka"/>
            <RadioButton x:Name="PayCard" Content="Karta"/>
            <RadioButton x:Name="PayOnline" Content="Online"/>
        </StackPanel>

        <Button Content="Zapłać" Margin="0,20,0,0" Click="Pay"/>
    </StackPanel>
</Window>
