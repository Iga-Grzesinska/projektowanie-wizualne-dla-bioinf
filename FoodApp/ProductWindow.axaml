<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FoodApp.ProductWindow"
        Title="Produkty" Width="350" Height="300">

    <StackPanel Margin="20">
        <TextBlock Text="Wybierz produkt:" FontSize="18"/>

        <ListBox x:Name="ProductList" Height="150"/>

        <CheckBox x:Name="ExtraSauce" Content="Dodatkowy sos +2 zł" Margin="0,10,0,0"/>

        <Button Content="Dodaj" Margin="0,20,0,0" Click="AddProduct"/>
    </StackPanel>

</Window>
