<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CalculatorGUI.MainWindow"
        Width="300"
        Height="250"
        Title="Calculator">

    <StackPanel Margin="20" Spacing="10">

        <TextBox Name="Input1" Watermark="First number"/>

        <TextBox Name="Input2" Watermark="Second number"/>

        <StackPanel Orientation="Horizontal" Spacing="5">
            <Button Content="+" Click="Add_Click"/>
            <Button Content="-" Click="Sub_Click"/>
            <Button Content="*" Click="Mul_Click"/>
            <Button Content="/" Click="Div_Click"/>
        </StackPanel>

        <TextBlock Name="ResultText"
                   Text="Result will appear here"
                   FontSize="16"/>

    </StackPanel>

</Window>