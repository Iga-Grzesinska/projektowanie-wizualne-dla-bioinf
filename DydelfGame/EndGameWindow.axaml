<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DydelfGame.EndGameWindow"
        Title="Koniec gry"
        Width="300" Height="150"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20" Spacing="15" HorizontalAlignment="Center">
        <TextBlock x:Name="MessageText" FontSize="16" TextWrapping="Wrap" HorizontalAlignment="Center"/>
        <Button Content="OK" Width="100" HorizontalAlignment="Center" Click="OK_Click"/>
    </StackPanel>

</Window>