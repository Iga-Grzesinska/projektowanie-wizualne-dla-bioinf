<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ImageApp.MainWindow"
        Width="800"
        Height="500"
        Title="Image App">

    <StackPanel Margin="20" Spacing="10">

        <Image Name="MainImage"
               Height="350"
               Stretch="Uniform"/>

        <WrapPanel Spacing="10">

            <Button Content="Load"
                    Click="LoadImage_Click"/>

            <Button Content="Rotate 90°"
                    Click="Rotate90_Click"/>
            
            <Button Content="Invert Colors"
                    Click="Invert_Click"/>

            <Button Content="Upside Down"
                    Click="Flip_Click"/>
            
            <Button Content="Only Green"
                    Click="Green_Click"/>

        </WrapPanel>

    </StackPanel>

</Window>