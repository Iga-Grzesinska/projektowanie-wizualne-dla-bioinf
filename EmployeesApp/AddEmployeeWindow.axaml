<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EmployeesApp.AddEmployeeWindow"
        Width="400" Height="250"
        Title="Dodaj pracownika">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
    
        <TextBlock Text="Imię:" Grid.Row="0" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="ImieTextBox" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Nazwisko:" Grid.Row="1" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="NazwiskoTextBox" Grid.Row="1" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Wiek:" Grid.Row="2" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="WiekTextBox" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <TextBlock Text="Stanowisko:" Grid.Row="3" Grid.Column="0" Margin="5"/>
        <ComboBox x:Name="StanowiskoComboBox"
          Grid.Row="3"
          Grid.Column="1"
          Margin="5">
    <ComboBox.Items>
        <x:String>Manager</x:String>
        <x:String>Programista</x:String>
        <x:String>HR</x:String>
    </ComboBox.Items>
</ComboBox>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button Content="OK" Width="80" Margin="5" Click="OkButton_Click"/>
            <Button Content="Anuluj" Width="80" Margin="5" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>

    
</Window>